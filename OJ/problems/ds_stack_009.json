{"id":"ds_stack_009","title":"Dãy ngoặc đúng","category":"data_structure","description":"Cho một xâu chỉ gồm các ký tự (, ), {, }, [, ]. Kiểm tra xem dãy ngoặc có đúng hay không.","input_format":"Một dòng là xâu S.","output_format":"YES nếu dãy ngoặc đúng, NO nếu không.","constraints":"1 ≤ |S| ≤ 10^5","difficulty":"easy","cf_rating":900,"time_limit":1,"memory_limit":256,"subtasks":[{"id":1,"points":20,"constraints":"len ≤ 10"},{"id":2,"points":30,"constraints":"len ≤ 1000"},{"id":3,"points":50,"constraints":"len ≤ 10^5"}],"samples":[{"input":"()[]{}","output":"YES"},{"input":"(]","output":"NO"}],"test_cases":[{"input":"()","output":"YES","subtask":1},{"input":"()[]{}","output":"YES","subtask":1},{"input":"(]","output":"NO","subtask":1},{"input":"([)]","output":"NO","subtask":2},{"input":"{[]}","output":"YES","subtask":2},{"input":"((()))","output":"YES","subtask":2},{"input":"({[})","output":"NO","subtask":2},{"input":"((())(()))","output":"YES","subtask":3},{"input":"((((","output":"NO","subtask":3},{"input":"()()()()","output":"YES","subtask":3},{"input":"({[]}){}[]","output":"YES","subtask":3},{"input":"((()))[]{}","output":"YES","subtask":3}]}