{"id":"greedy_smallest_003","title":"Số nhỏ nhất","category":"greedy","description":"Cho số nguyên N và số K. Hãy xoá đúng K chữ số từ N để thu được số nhỏ nhất có thể (giữ nguyên thứ tự các chữ số còn lại).","input_format":"Một dòng gồm N (số nguyên dương) và K (0 ≤ K < số chữ số của N).","output_format":"Số nhỏ nhất sau khi xoá K chữ số.","constraints":"N ≤ 10^1000, 0 ≤ K < len(N)","difficulty":"medium","cf_rating":1200,"time_limit":1,"memory_limit":256,"subtasks":[{"id":1,"points":20,"constraints":"số chữ số ≤ 4"},{"id":2,"points":30,"constraints":"số chữ số ≤ 10"},{"id":3,"points":50,"constraints":"số chữ số ≤ 1000"}],"samples":[{"input":"1432219 3","output":"1219"}],"test_cases":[{"input":"143 1","output":"13","subtask":1},{"input":"10200 1","output":"0200","subtask":1},{"input":"4321 2","output":"21","subtask":1},{"input":"12345 3","output":"12","subtask":2},{"input":"1432219 3","output":"1219","subtask":2},{"input":"100200 1","output":"00200","subtask":2},{"input":"937416 3","output":"316","subtask":3},{"input":"123456789 5","output":"1234","subtask":3},{"input":"999999 3","output":"999","subtask":3},{"input":"987654321 4","output":"54321","subtask":3}]}