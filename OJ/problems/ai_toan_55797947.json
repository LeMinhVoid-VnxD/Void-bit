{"id":"ai_toan_55797947","title":"Cặp số thần kỳ","category":"toan","description":"Cho hai số nguyên dương a và b. Hãy tìm ước chung lớn nhất (GCD) và bội chung nhỏ nhất (LCM) của hai số đó.","input_format":"Một dòng duy nhất chứa hai số nguyên dương a và b.","output_format":"Một dòng duy nhất chứa hai số nguyên là GCD(a, b) và LCM(a, b), cách nhau bởi một dấu cách.","constraints":"1 <= a, b <= 10^9","difficulty":"easy","cf_rating":800,"time_limit":1,"memory_limit":256,"subtasks":[{"id":1,"points":20,"constraints":"1 <= a, b <= 100"},{"id":2,"points":30,"constraints":"1 <= a, b <= 10^5"},{"id":3,"points":50,"constraints":"1 <= a, b <= 10^9"}],"samples":[{"input":"12 18\n","output":"6 36\n","explanation":"GCD của 12 và 18 là 6. LCM của 12 và 18 là 36."}],"test_cases":[{"input":"1 1\n","output":"1 1\n","subtask":1},{"input":"5 7\n","output":"1 35\n","subtask":1},{"input":"10 20\n","output":"10 20\n","subtask":1},{"input":"100 100\n","output":"100 100\n","subtask":1},{"input":"123 456\n","output":"3 18696\n","subtask":2},{"input":"99999 100000\n","output":"1 9999900000\n","subtask":2},{"input":"100000 100000\n","output":"100000 100000\n","subtask":2},{"input":"999999937 1\n","output":"1 999999937\n","subtask":3},{"input":"999999937 999999937\n","output":"999999937 999999937\n","subtask":3},{"input":"1000000000 999999999\n","output":"1 999999999000000000\n","subtask":3},{"input":"500000000 250000000\n","output":"250000000 500000000\n","subtask":3},{"input":"987654321 123456789\n","output":"9 13548074668518539\n","subtask":3}]}