{"id":"graph_cycle_016","title":"Phát hiện chu trình","category":"graph","description":"Cho đồ thị vô hướng N đỉnh, M cạnh. Kiểm tra xem đồ thị có chứa chu trình hay không.","input_format":"Dòng 1: N và M. M dòng sau: u và v.","output_format":"YES nếu có chu trình, NO nếu không.","constraints":"1 ≤ N ≤ 10^5, 0 ≤ M ≤ 10^5","difficulty":"medium","cf_rating":1100,"time_limit":1,"memory_limit":256,"subtasks":[{"id":1,"points":20,"constraints":"N ≤ 10"},{"id":2,"points":30,"constraints":"N ≤ 1000"},{"id":3,"points":50,"constraints":"N ≤ 10^5"}],"samples":[{"input":"3 3\n1 2\n2 3\n3 1","output":"YES"}],"test_cases":[{"input":"4 3\n1 2\n2 3\n3 4","output":"NO","subtask":1},{"input":"4 4\n1 2\n2 3\n3 4\n4 1","output":"YES","subtask":1},{"input":"5 4\n1 2\n2 3\n3 4\n4 5","output":"NO","subtask":2},{"input":"6 6\n1 2\n2 3\n3 1\n4 5\n5 6\n6 4","output":"YES","subtask":2},{"input":"7 5\n1 2\n2 3\n3 4\n5 6\n6 7","output":"NO","subtask":2},{"input":"8 8\n1 2\n2 3\n3 4\n4 1\n5 6\n6 7\n7 8\n8 5","output":"YES","subtask":3},{"input":"10 9\n1 2\n2 3\n3 4\n4 5\n5 1\n6 7\n7 8\n8 9\n9 10","output":"YES","subtask":3},{"input":"10 8\n1 2\n2 3\n3 4\n5 6\n6 7\n7 8\n8 9\n9 5","output":"YES","subtask":3}]}