{"id":"ai_dp_95279262","title":"Tổng dãy con liên tiếp lớn nhất","category":"dp","description":"Cho một dãy số nguyên gồm n phần tử A = [a1, a2, ..., an]. Hãy tìm tổng của một dãy con liên tiếp (subsegment) có tổng lớn nhất. Dãy con phải có độ dài ít nhất là 1 phần tử.","input_format":"Dòng đầu tiên chứa số nguyên n (1 <= n <= 10^5). Dòng thứ hai chứa n số nguyên a1, a2, ..., an (-10^4 <= ai <= 10^4).","output_format":"In ra một số nguyên duy nhất là tổng lớn nhất tìm được.","constraints":"1 <= n <= 10^5, -10^4 <= ai <= 10^4","difficulty":"medium","cf_rating":1100,"time_limit":1,"memory_limit":256,"subtasks":[{"id":1,"points":20,"constraints":"n <= 100"},{"id":2,"points":30,"constraints":"n <= 5000"},{"id":3,"points":50,"constraints":"n <= 100000"}],"samples":[{"input":"8\n-2 1 -3 4 -1 2 1 -5 4\n","output":"6\n","explanation":"Dãy con [4, -1, 2, 1] có tổng là 6."}],"test_cases":[{"input":"1\n-5\n","output":"-5\n","subtask":1},{"input":"2\n10 20\n","output":"30\n","subtask":1},{"input":"5\n-1 -2 -3 -4 -5\n","output":"-1\n","subtask":1},{"input":"3\n10 -20 10\n","output":"10\n","subtask":1},{"input":"5\n1 2 3 4 5\n","output":"15\n","subtask":2},{"input":"6\n-2 1 -3 4 -1 2\n","output":"5\n","subtask":2},{"input":"5\n-5 -1 -5 -2 -3\n","output":"-1\n","subtask":2},{"input":"5\n100 -1000 100 100 100\n","output":"300\n","subtask":2},{"input":"10\n1 2 3 4 5 -100 1 2 3 4\n","output":"15\n","subtask":3},{"input":"5\n-10000 -10000 -10000 -10000 -10000\n","output":"-10000\n","subtask":3},{"input":"4\n-1 10 -1 10\n","output":"19\n","subtask":3},{"input":"3\n-5 0 -5\n","output":"0\n","subtask":3},{"input":"6\n10000 10000 10000 10000 10000 10000\n","output":"60000\n","subtask":3},{"input":"6\n-10000 -10000 10000 10000 -10000 -10000\n","output":"20000\n","subtask":3}]}