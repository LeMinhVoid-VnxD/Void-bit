{"id":"ai_toan_75441719","title":"Tổng ước số lũy thừa","category":"toan","description":"Cho hai số nguyên dương n và k. Gọi σ_k(n) là tổng lũy thừa bậc k của các ước số của n, tức là σ_k(n) = Σ_{d|n} d^k. Cho trước số nguyên N, hãy tính giá trị S = Σ_{i=1}^N σ_k(i) mod (10^9 + 7).","input_format":"Một dòng duy nhất chứa hai số nguyên N và k.","output_format":"In ra giá trị S mod (10^9 + 7).","constraints":"1 <= N <= 10^10, 1 <= k <= 10^6.","difficulty":"hard","cf_rating":2200,"time_limit":1,"memory_limit":256,"subtasks":[{"id":1,"points":20,"constraints":"N <= 10^5, k <= 100"},{"id":2,"points":30,"constraints":"N <= 10^7, k <= 1000"},{"id":3,"points":50,"constraints":"N <= 10^10, k <= 10^6"}],"samples":[{"input":"6 2\n","output":"225\n","explanation":"σ_2(1)=1, σ_2(2)=5, σ_2(3)=10, σ_2(4)=21, σ_2(5)=26, σ_2(6)=162. Tổng = 225."}],"test_cases":[{"input":"1 1\n","output":"1\n","subtask":1},{"input":"2 1\n","output":"4\n","subtask":1},{"input":"10 2\n","output":"1050\n","subtask":1},{"input":"100 1\n","output":"8217\n","subtask":2},{"input":"1000 3\n","output":"672456488\n","subtask":2},{"input":"100000 1\n","output":"822467657\n","subtask":2},{"input":"1000000 2\n","output":"858882655\n","subtask":2},{"input":"5000000 1\n","output":"435133907\n","subtask":2},{"input":"1000000000 1\n","output":"468532450\n","subtask":3},{"input":"10000000000 2\n","output":"252554766\n","subtask":3},{"input":"9999999999 1\n","output":"722744662\n","subtask":3},{"input":"5000000000 10\n","output":"644020967\n","subtask":3},{"input":"7777777777 5\n","output":"249826359\n","subtask":3}]}