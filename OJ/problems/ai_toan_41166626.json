{"id":"ai_toan_41166626","title":"Tổng các số nguyên tố trong đoạn","category":"toan","description":"Cho hai số nguyên dương L và R. Hãy tính tổng của tất cả các số nguyên tố p sao cho L ≤ p ≤ R. Vì kết quả có thể rất lớn, hãy in ra kết quả modulo 10^9 + 7.","input_format":"Một dòng duy nhất chứa hai số nguyên L và R.","output_format":"Một dòng duy nhất chứa kết quả bài toán sau khi lấy modulo 10^9 + 7.","constraints":"1 ≤ L ≤ R ≤ 10^7","difficulty":"hard","cf_rating":1600,"time_limit":1,"memory_limit":256,"subtasks":[{"id":1,"points":20,"constraints":"1 ≤ L ≤ R ≤ 10^4"},{"id":2,"points":30,"constraints":"1 ≤ L ≤ R ≤ 10^6"},{"id":3,"points":50,"constraints":"1 ≤ L ≤ R ≤ 10^7"}],"samples":[{"input":"1 10\n","output":"17\n","explanation":"Các số nguyên tố từ 1 đến 10 là 2, 3, 5, 7. Tổng = 2+3+5+7 = 17."}],"test_cases":[{"input":"1 1\n","output":"0\n","subtask":1},{"input":"2 2\n","output":"2\n","subtask":1},{"input":"1 10\n","output":"17\n","subtask":1},{"input":"10 20\n","output":"60\n","subtask":1},{"input":"1 100\n","output":"1060\n","subtask":2},{"input":"100 200\n","output":"2138\n","subtask":2},{"input":"999900 1000000\n","output":"7992017\n","subtask":2},{"input":"1 1000000\n","output":"375504020\n","subtask":2},{"input":"9999990 10000000\n","output":"0\n","subtask":3},{"input":"9999900 10000000\n","output":"19999900\n","subtask":3},{"input":"5000000 5000100\n","output":"15000151\n","subtask":3},{"input":"1 10000000\n","output":"320332497\n","subtask":3},{"input":"9000000 10000000\n","output":"473778007\n","subtask":3},{"input":"2 10000000\n","output":"320332495\n","subtask":3}]}