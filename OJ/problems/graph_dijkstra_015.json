{"id":"graph_dijkstra_015","title":"Đường đi ngắn nhất","category":"graph","description":"Cho đồ thị vô hướng có trọng số N đỉnh, M cạnh. Tìm đường đi ngắn nhất từ đỉnh A đến đỉnh B.","input_format":"Dòng 1: N, M. M dòng sau: u, v, w. Dòng cuối: A và B.","output_format":"Khoảng cách ngắn nhất, hoặc -1 nếu không có đường đi.","constraints":"1 ≤ N ≤ 10^5, 1 ≤ M ≤ 2*10^5, 1 ≤ w ≤ 10^9","difficulty":"hard","cf_rating":1400,"time_limit":1,"memory_limit":256,"subtasks":[{"id":1,"points":20,"constraints":"N ≤ 10"},{"id":2,"points":30,"constraints":"N ≤ 1000"},{"id":3,"points":50,"constraints":"N ≤ 10^5"}],"samples":[{"input":"4 4\n1 2 1\n2 3 2\n3 4 3\n1 4 10\n1 4","output":"6"}],"test_cases":[{"input":"4 4\n1 2 1\n2 3 2\n3 4 3\n1 4 10\n1 4","output":"6","subtask":1},{"input":"5 5\n1 2 5\n1 3 2\n3 4 3\n4 5 1\n2 5 2\n1 5","output":"6","subtask":1},{"input":"6 7\n1 2 4\n1 3 2\n2 4 3\n3 4 1\n3 5 6\n4 6 2\n5 6 3\n1 6","output":"5","subtask":2},{"input":"7 8\n1 2 10\n1 3 3\n2 4 2\n3 4 4\n3 5 8\n4 6 5\n5 7 2\n6 7 1\n1 7","output":"13","subtask":2},{"input":"8 10\n1 2 4\n2 3 2\n3 4 6\n4 5 3\n5 6 1\n6 7 5\n7 8 2\n1 8 12\n2 6 7\n3 7 4\n1 8","output":"12","subtask":3},{"input":"10 12\n1 2 2\n2 3 3\n3 4 4\n4 5 5\n5 6 6\n6 7 7\n7 8 8\n8 9 9\n9 10 10\n1 10 15\n2 9 8\n3 8 5\n1 10","output":"15","subtask":3}]}