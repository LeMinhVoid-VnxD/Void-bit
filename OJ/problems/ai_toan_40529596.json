{"id":"ai_toan_40529596","title":"Tổng dãy con chia hết cho K","category":"math","description":"Cho một dãy số nguyên A gồm N phần tử. Hãy đếm số lượng dãy con liên tiếp có tổng chia hết cho K.","input_format":"Dòng đầu tiên chứa hai số nguyên N và K. Dòng thứ hai chứa N số nguyên A_1, A_2, ..., A_N.","output_format":"Một số nguyên duy nhất là số lượng dãy con liên tiếp có tổng chia hết cho K.","constraints":"1 <= N <= 10^5, 1 <= K <= 10^5, -10^9 <= A_i <= 10^9.","difficulty":"hard","cf_rating":1600,"time_limit":1,"memory_limit":256,"subtasks":[{"id":1,"points":20,"constraints":"N <= 1000"},{"id":2,"points":30,"constraints":"N <= 10^5, K = 1"},{"id":3,"points":50,"constraints":"N <= 10^5, K <= 10^5"}],"samples":[{"input":"5 3\n1 2 3 4 5\n","output":"4\n","explanation":"[1,2], [3], [1,2,3], [2,3,4] là các dãy con có tổng chia hết cho 3."}],"test_cases":[{"input":"5 3\n1 2 3 4 5\n","output":"4\n","subtask":1},{"input":"3 1\n1 2 3\n","output":"6\n","subtask":2},{"input":"1 5\n10\n","output":"1\n","subtask":1},{"input":"4 2\n1 1 1 1\n","output":"6\n","subtask":3},{"input":"5 2\n-1 1 -1 1 -1\n","output":"9\n","subtask":3},{"input":"2 10\n5 5\n","output":"2\n","subtask":3},{"input":"6 4\n2 2 2 2 2 2\n","output":"6\n","subtask":3},{"input":"3 7\n0 0 0\n","output":"6\n","subtask":3},{"input":"4 3\n1 -1 1 -1\n","output":"2\n","subtask":3},{"input":"5 5\n1 2 3 4 5\n","output":"2\n","subtask":3},{"input":"3 2\n1000000000 1000000000 1000000000\n","output":"6\n","subtask":3},{"input":"1 1\n0\n","output":"1\n","subtask":2},{"input":"6 3\n1 1 1 1 1 1\n","output":"6\n","subtask":3},{"input":"2 100\n50 50\n","output":"1\n","subtask":3}]}